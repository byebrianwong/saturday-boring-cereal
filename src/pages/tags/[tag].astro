---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MiniBox from '../../components/MiniBox.astro';
import PriceTag from '../../components/PriceTag.astro';
import { label } from '../../lib/taxonomy';
import { macroLine, byRatingDesc } from '../../lib/macros';
import { u } from '../../lib/url';

export async function getStaticPaths() {
  const cereals = await getCollection('cereals');
  const groups = new Map<string, { kind: string; list: typeof cereals }>();
  const add = (tag: string, kind: string, c: (typeof cereals)[number]) => {
    if (!groups.has(tag)) groups.set(tag, { kind, list: [] as unknown as typeof cereals });
    groups.get(tag)!.list.push(c);
  };
  for (const c of cereals) {
    for (const t of c.data.formFactors) add(t, 'Form factor', c);
    for (const t of c.data.attributes) add(t, 'Attribute', c);
    for (const t of c.data.proteinSources) add(t, 'Protein source', c);
  }
  return [...groups].map(([tag, { kind, list }]) => ({
    params: { tag },
    props: { tag, kind, list: [...list].sort(byRatingDesc) },
  }));
}

const { tag, kind, list } = Astro.props;
const title = label(tag);
---

<Layout
  title={`${title} — Saturday Boring Cereal`}
  description={`Every ${title.toLowerCase()} cereal in the aisle, ranked.`}
>
  <div class="light"></div>

  <div class="crumb wrap"><a href={u('/cereals/')}>← BACK TO THE FULL AISLE</a></div>

  <div class="signrow wrap">
    <div class="aislesign">
      <small>{kind.toUpperCase()}</small>
      <span>{title}</span>
    </div>
  </div>
  <p class="count wrap">{list.length} box{list.length === 1 ? '' : 'es'} on this shelf, ranked best first.</p>

  <div class="aislegrid wrap">
    {
      list.map((c) => (
        <div class="cell">
          <MiniBox
            emoji={c.data.emoji}
            brand={c.data.brand}
            name={c.data.name}
            boxColor={c.data.boxColor}
            boxImage={c.data.boxImage}
            href={`/cereals/${c.id}/`}
          />
          <div class="shelfbar" />
          <PriceTag rating={c.data.rating} macros={macroLine(c)} />
        </div>
      ))
    }
  </div>
</Layout>

<style>
  .crumb {
    margin-top: 22px;
  }

  .crumb a {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: var(--store-blue-dark);
  }

  .crumb a:hover {
    text-decoration: underline;
  }

  .signrow {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .aislesign {
    background: var(--store-blue);
    color: #fff;
    text-align: center;
    padding: 16px 40px 14px;
    border-radius: 8px 8px 3px 3px;
    position: relative;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.28);
  }

  .aislesign::before,
  .aislesign::after {
    content: '';
    position: absolute;
    top: -14px;
    width: 3px;
    height: 14px;
    background: #90a4ae;
  }

  .aislesign::before {
    left: 30%;
  }

  .aislesign::after {
    right: 30%;
  }

  .aislesign small {
    display: block;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: #bfe0ff;
    margin-bottom: 4px;
  }

  .aislesign span {
    font-size: 26px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .count {
    text-align: center;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 13.5px;
    color: #6b4a2a;
    margin-top: 12px;
  }

  .aislegrid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 34px 18px;
    max-width: 980px;
    margin: 34px auto 0;
  }

  .cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    perspective: 900px;
  }

  .cell > :global(.shelfbar) {
    width: 100%;
    margin-top: -2px;
  }

  .cell > :global(.ptag) {
    width: 118px;
    margin-top: -1px;
  }
</style>
