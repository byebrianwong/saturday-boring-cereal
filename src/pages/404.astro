---
import Layout from '../layouts/Layout.astro';
import { u } from '../lib/url';
---

<Layout title="Aisle Not Found — Saturday Boring Cereal">
  <div class="light"></div>
  <div class="wrap oops">
    <div class="sign">
      <small>AISLE</small>
      <span>404</span>
    </div>
    <h1>WE DON'T STOCK THAT</h1>
    <p>
      You've wandered into an aisle that doesn't exist. It happens. The shelves here are
      finite, the milk is warm, and a stock clerk (one man) has been notified.
    </p>
    <div class="links">
      <a class="cta" href={u('/')}>← BACK TO THE FRONT</a>
      <a class="cta ghost" href={u('/cereals/')}>WALK THE AISLE</a>
    </div>
    <div class="shelfbar"></div>
  </div>
</Layout>

<style>
  .oops {
    max-width: 620px;
    text-align: center;
    padding-top: 30px;
  }

  .sign {
    display: inline-block;
    background: var(--store-blue);
    color: #fff;
    padding: 16px 44px 14px;
    border-radius: 8px 8px 3px 3px;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.28);
    margin-bottom: 26px;
  }

  .sign small {
    display: block;
    font-size: 10px;
    letter-spacing: 0.35em;
    color: #bfe0ff;
  }

  .sign span {
    font-size: 44px;
    letter-spacing: 0.1em;
  }

  h1 {
    font-size: 30px;
    color: var(--red);
    letter-spacing: 0.04em;
  }

  p {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 15px;
    line-height: 1.6;
    color: #6b4a2a;
    margin: 14px auto 26px;
    max-width: 480px;
  }

  .links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 34px;
  }

  .cta {
    display: inline-block;
    background: var(--red);
    color: #fff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.12em;
    padding: 11px 18px;
    border-radius: 4px;
    box-shadow: 0 4px 0 var(--brown);
  }

  .cta.ghost {
    background: #fff;
    color: var(--red);
    border: 2px solid var(--red);
    box-shadow: 0 4px 0 rgba(211, 47, 47, 0.3);
  }

  .cta:hover {
    transform: translateY(-2px);
  }

  .oops .shelfbar {
    max-width: 360px;
    margin: 0 auto;
  }
</style>
