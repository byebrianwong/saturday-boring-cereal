---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import AisleFilters from '../components/AisleFilters.astro';
import MiniBox from '../components/MiniBox.astro';
import PriceTag from '../components/PriceTag.astro';
import Receipt from '../components/Receipt.astro';
import { macroLine, byRatingDesc } from '../lib/macros';
import { label } from '../lib/taxonomy';
import { u } from '../lib/url';

const cereals = await getCollection('cereals');
// Unrated (null) cereals sort last.
const ranked = [...cereals].sort(byRatingDesc);

// Tag counts for the "browse the aisles" section (form factors + attributes).
const tagCounts = new Map<string, number>();
for (const c of cereals) {
  for (const t of [...c.data.formFactors, ...c.data.attributes]) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const browseTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const shelves: (typeof ranked)[] = [];
for (let i = 0; i < Math.min(ranked.length, 6); i += 3) {
  shelves.push(ranked.slice(i, i + 3));
}

const recent = [...cereals]
  .sort((a, b) => b.data.dateReviewed.getTime() - a.data.dateReviewed.getTime())
  .slice(0, 3)
  .map((c) => ({
    title: `${c.data.brand} ${c.data.name}`,
    rating: c.data.rating,
    note: c.data.shortNote ?? '',
    href: `/cereals/${c.id}/`,
  }));
---

<Layout>
  <div class="light"></div>

  <div class="scene wrap">
    <div class="box3d">
      <div class="face front">
        <div class="oval">
          <small>SATURDAY</small>
          <h1>BORING<br />CEREAL</h1>
        </div>
        <div class="bowl">🥣</div>
        <div class="claim">NOW FORTIFIED WITH OPINIONS</div>
      </div>
      <div class="face side">
        <h4>Nutrition Facts</h4>
        <div class="nf">
          <div><span><b>Cereals ranked</b></span><span>{cereals.length}</span></div>
          <div><span>Taste scale</span><span>0–10</span></div>
          <div><span>Mascots</span><span>0g</span></div>
          <div><span>Honesty</span><span>110%</span></div>
        </div>
        <div class="upc"></div>
      </div>
    </div>
    <div class="herotext">
      <div class="sticker">SHELVED FRESH EVERY SATURDAY</div>
      <h2>THE ONLY AISLE<br />WHERE <em>BORING</em><br />IS A BRAG</h2>
      <p>
        One man walks the healthy-cereal aisle so you don't have to. Every box tasted, weighed,
        and priced in cold, hard macros.
      </p>
      <a class="cta" href={u('/cereals/')}>WALK THE AISLE →</a>
    </div>
  </div>
  <div class="shelf-hero"></div>

  <AisleFilters mode="links" />

  <h3 class="rowlabel">— TOP SHELF · RANKED LEFT TO RIGHT —</h3>
  <div class="shelfrow wrap">
    {
      shelves.map((row) => (
        <>
          <div class="boxes">
            {row.map((c) => (
              <MiniBox
                emoji={c.data.emoji}
                brand={c.data.brand}
                name={c.data.name}
                boxColor={c.data.boxColor}
                boxImage={c.data.boxImage}
                href={`/cereals/${c.id}/`}
              />
            ))}
          </div>
          <div class="shelfbar" />
          <div class="pricetags">
            {row.map((c) => (
              <PriceTag rating={c.data.rating} macros={macroLine(c)} />
            ))}
          </div>
        </>
      ))
    }
  </div>

  <h3 class="rowlabel">— BROWSE THE AISLES —</h3>
  <div class="browse wrap">
    {
      browseTags.map(([tag, n]) => (
        <a class="browsetag" href={u(`/tags/${tag}/`)}>
          {label(tag)}<span class="bn">{n}</span>
        </a>
      ))
    }
  </div>

  <div class="checkout wrap">
    <Receipt lines={recent} />
  </div>
</Layout>

<style>
  /* hero: the big 3D box */
  .scene {
    display: flex;
    justify-content: center;
    gap: 60px;
    align-items: flex-end;
    perspective: 1100px;
    padding-top: 40px;
    flex-wrap: wrap;
  }

  .box3d {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(-24deg) rotateX(2deg);
    width: 300px;
    height: 400px;
    flex: 0 0 auto;
  }

  .face {
    position: absolute;
    inset: 0;
  }

  .front {
    background: var(--red);
    border: 5px solid var(--brown);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-image: repeating-linear-gradient(45deg, rgba(0, 0, 0, 0.06) 0 18px, transparent 18px 36px);
  }

  .front .oval {
    background: var(--cream);
    border: 4px solid var(--brown);
    border-radius: 50%;
    padding: 26px 34px;
    transform: rotate(-3deg);
  }

  .front .oval small {
    display: block;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--red);
  }

  .front .oval h1 {
    font-size: 34px;
    line-height: 0.95;
    color: var(--red);
    text-shadow: 2px 2px 0 var(--yellow);
  }

  .front .bowl {
    font-size: 64px;
    margin-top: 14px;
    filter: drop-shadow(0 6px 4px rgba(0, 0, 0, 0.3));
  }

  .front .claim {
    background: var(--yellow);
    color: var(--red);
    font-size: 10px;
    padding: 5px 12px;
    border-radius: 999px;
    margin-top: 10px;
    transform: rotate(-2deg);
  }

  .side {
    width: 110px;
    transform: rotateY(90deg) translateZ(-55px) translateX(55px);
    left: auto;
    right: -110px;
    background: var(--red-dark);
    border: 5px solid var(--brown);
    border-left: 0;
    padding: 12px 10px;
    color: var(--cream);
  }

  .side h4 {
    background: #fff;
    color: #000;
    font-family: var(--font-label);
    font-size: 13px;
    padding: 3px 5px;
    border: 2px solid #000;
    margin-bottom: 6px;
  }

  .side .nf {
    background: #fff;
    color: #000;
    font-family: var(--font-label);
    font-size: 8.5px;
    padding: 5px;
    border: 2px solid #000;
    line-height: 1.5;
  }

  .side .nf div {
    border-bottom: 1px solid #000;
    display: flex;
    justify-content: space-between;
  }

  .side .nf div:last-child {
    border-bottom: 0;
  }

  .side .upc {
    margin-top: 8px;
    height: 34px;
    background: repeating-linear-gradient(90deg, #000 0 2px, #fff 2px 5px, #000 5px 6px, #fff 6px 10px);
  }

  .herotext {
    max-width: 330px;
    padding-bottom: 30px;
  }

  .herotext .sticker {
    margin-bottom: 12px;
  }

  .herotext h2 {
    font-size: 30px;
    line-height: 1.05;
  }

  .herotext h2 em {
    font-style: normal;
    color: var(--red);
  }

  .herotext p {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.55;
    margin-top: 10px;
    font-style: italic;
    color: #6b4a2a;
  }

  .cta {
    display: inline-block;
    margin-top: 16px;
    background: var(--red);
    color: #fff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.12em;
    padding: 10px 16px;
    border-radius: 4px;
    box-shadow: 0 4px 0 var(--brown);
  }

  .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 var(--brown);
  }

  .shelf-hero {
    max-width: 900px;
    margin: -6px auto 0;
    height: 26px;
    background: linear-gradient(var(--shelfwood-light), var(--shelfwood));
    border-radius: 3px;
    box-shadow: 0 14px 22px rgba(0, 0, 0, 0.28);
  }

  /* shelves */
  .shelfrow {
    max-width: 980px;
  }

  .boxes {
    display: flex;
    justify-content: center;
    gap: 42px;
    align-items: flex-end;
    padding: 30px 0 0;
    perspective: 900px;
  }

  .pricetags {
    display: flex;
    justify-content: center;
    gap: 42px;
    margin-top: -11px;
  }

  .pricetags > :global(.ptag) {
    width: 118px;
  }

  .browse {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    max-width: 760px;
    margin: 16px auto 0;
  }

  .browsetag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #fff;
    border: 2px solid var(--store-blue);
    color: var(--store-blue-dark);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 7px 10px 7px 13px;
    border-radius: 999px;
  }

  .browsetag:hover {
    background: var(--store-blue);
    color: #fff;
  }

  .browsetag .bn {
    background: var(--floor);
    color: var(--tag-gray);
    font-size: 10px;
    border-radius: 999px;
    padding: 1px 7px;
  }

  .browsetag:hover .bn {
    background: rgba(255, 255, 255, 0.85);
  }

  .checkout {
    display: flex;
    justify-content: center;
    padding: 46px 20px 10px;
  }

  @media (max-width: 760px) {
    .scene {
      gap: 30px;
    }

    .boxes,
    .pricetags {
      gap: 20px;
    }
  }
</style>
