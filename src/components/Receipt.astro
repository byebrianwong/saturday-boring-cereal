---
import { rating as fmtRating, receiptDate } from '../lib/format';

interface ReceiptLine {
  title: string;
  rating: number | null;
  note: string;
  href?: string;
  date?: Date;
}

interface Props {
  lines: ReceiptLine[];
  heading?: string;
  showDates?: boolean;
}

const { lines, heading = '*** RECENT REVIEWS ***', showDates = false } = Astro.props;
---

<div class="receipt">
  <h4>SATURDAY BORING CEREAL</h4>
  <div class="c">LANE 1 · CASHIER: BRIAN<br />{heading}</div>
  {
    lines.map((l) => (
      <>
        <div class="ln">
          {l.href ? <a href={l.href}>{l.title}</a> : <span>{l.title}</span>}
          <span class="r">
            {showDates && l.date ? <span class="d">{receiptDate(l.date)} </span> : null}
            {fmtRating(l.rating)}
          </span>
        </div>
        <div class:list={['note', { blank: !l.note }]}>{l.note || '— no tasting note on file —'}</div>
      </>
    ))
  }
  <div class="tot"><span>TOTAL REGRET</span><span>0.00</span></div>
  <div class="tot thin"><span>MASCOTS PURCHASED</span><span>0</span></div>
  <div class="barcode"></div>
  <div class="thanks">THANK YOU FOR EATING RESPONSIBLY</div>
</div>

<style>
  .receipt {
    background: #fdfdf8;
    width: 100%;
    max-width: 420px;
    padding: 22px 24px;
    font-family: var(--font-receipt);
    font-size: 11.5px;
    color: #222;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.25);
    clip-path: polygon(
      0 0, 100% 0, 100% 98%, 96% 100%, 92% 98%, 88% 100%, 84% 98%, 80% 100%,
      76% 98%, 72% 100%, 68% 98%, 64% 100%, 60% 98%, 56% 100%, 52% 98%,
      48% 100%, 44% 98%, 40% 100%, 36% 98%, 32% 100%, 28% 98%, 24% 100%,
      20% 98%, 16% 100%, 12% 98%, 8% 100%, 4% 98%, 0 100%
    );
  }

  h4 {
    text-align: center;
    font-size: 13px;
    letter-spacing: 0.18em;
    margin-bottom: 2px;
    font-weight: bold;
  }

  .c {
    text-align: center;
    color: #666;
    margin-bottom: 10px;
  }

  .ln {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px dashed #bbb;
    padding: 7px 0 3px;
    text-transform: uppercase;
  }

  .ln a {
    color: inherit;
    text-decoration: none;
  }

  .ln a:hover {
    text-decoration: underline;
  }

  .r {
    white-space: nowrap;
  }

  .d {
    color: #999;
    font-size: 10px;
  }

  .note {
    color: #555;
    font-style: italic;
    padding: 2px 0 6px;
  }

  .note.blank {
    color: #aaa;
  }

  .tot {
    display: flex;
    justify-content: space-between;
    font-weight: bold;
    font-size: 12.5px;
    padding-top: 10px;
  }

  .tot.thin {
    font-weight: normal;
    padding-top: 2px;
  }

  .barcode {
    height: 36px;
    margin-top: 12px;
    background: repeating-linear-gradient(90deg, #000 0 2px, #fff 2px 4px, #000 4px 5px, #fff 5px 9px);
  }

  .thanks {
    text-align: center;
    margin-top: 8px;
    letter-spacing: 0.1em;
  }
</style>
