---
// A little 3D cereal box standing on the shelf.
interface Props {
  emoji: string;
  brand: string;
  name: string;
  boxColor: string;
  href?: string;
  boxImage?: string;
}

import { u } from '../lib/url';

const { emoji, brand, name, boxColor, href, boxImage } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="mini" href={href ? u(href) : undefined} style={`--bc: ${boxColor}`}>
  <div class:list={['mf', { hasphoto: boxImage }]}>
    {
      boxImage ? (
        <img class="photo" src={u(boxImage)} alt={`${brand} ${name}`} loading="lazy" />
      ) : (
        <>
          <div class="em">{emoji}</div>
          <div class="mb">{brand}</div>
          <h5>{name}</h5>
        </>
      )
    }
  </div>
  <div class="ms"></div>
</Tag>

<style>
  .mini {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(-18deg);
    width: 118px;
    height: 158px;
    transition: transform 0.15s;
    display: block;
    text-decoration: none;
  }

  a.mini:hover {
    transform: rotateY(-8deg) translateY(-6px);
  }

  .mf {
    position: absolute;
    inset: 0;
    border: 3px solid var(--brown);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6px;
    background: linear-gradient(145deg, var(--bc), color-mix(in srgb, var(--bc) 72%, #000));
    overflow: hidden;
  }

  .mf.hasphoto {
    padding: 0;
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ms {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 30px;
    right: -30px;
    transform: rotateY(90deg) translateZ(-15px) translateX(15px);
    border: 3px solid var(--brown);
    border-left: 0;
    opacity: 0.85;
    background: color-mix(in srgb, var(--bc) 60%, #000);
  }

  .em {
    font-size: 34px;
    filter: drop-shadow(0 3px 2px rgba(0, 0, 0, 0.3));
  }

  .mb {
    font-size: 7px;
    letter-spacing: 0.14em;
    color: #fff;
    background: rgba(0, 0, 0, 0.35);
    padding: 2px 6px;
    border-radius: 99px;
    margin-top: 6px;
    text-transform: uppercase;
  }

  h5 {
    font-size: 10px;
    color: #fff;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.4);
    margin-top: 4px;
    line-height: 1.15;
    font-family: var(--font-display);
  }
</style>
